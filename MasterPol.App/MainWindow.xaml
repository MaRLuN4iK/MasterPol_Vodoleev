<Window x:Class="MasterPol.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MasterPol.App"
        Title="Мастер Пол - Управление партнерами" 
        Height="780" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        WindowStyle="SingleBorderWindow"
        Background="#F5F7FA"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Стили для кнопок с цветами -->
        <Style x:Key="GreenButton" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#229954"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BlueButton" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RedButton" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CB4335"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OrangeButton" TargetType="Button">
            <Setter Property="Background" Value="#E67E22"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CA6F1E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PurpleButton" TargetType="Button">
            <Setter Property="Background" Value="#9B59B6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8E44AD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Конвертер для цвета скидки -->
        <local:DiscountToColorConverter x:Key="DiscountToColorConverter"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#2C3E50" Margin="0,0,0,10">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип и название -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Width="40" Height="40" Background="#3498DB">
                        <TextBlock Text="MP" FontSize="20" FontWeight="Bold" Foreground="White" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="МАСТЕР ПОЛ" FontSize="24" FontWeight="Bold" Foreground="White" 
                               VerticalAlignment="Center" Margin="15,0,0,0"/>
                    <TextBlock Text="Партнеры" FontSize="18" Foreground="#BDC3C7" 
                               VerticalAlignment="Center" Margin="15,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Панель действий -->
            <Border Grid.Row="0" Background="White" Padding="20" Margin="0,0,0,20" 
                    BorderBrush="#D5D8DC" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Заголовок и статистика -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="Список партнеров" FontSize="22" FontWeight="SemiBold" 
                                   Foreground="#2C3E50" VerticalAlignment="Center"/>
                        <Border Background="#3498DB" Padding="10,5" Margin="15,0,0,0">
                            <TextBlock x:Name="TxtPartnerCount" Text="0" FontSize="14" 
                                       FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </StackPanel>

                    <!-- Кнопки действий -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnAddPartner" Style="{StaticResource GreenButton}"
            Margin="0,0,10,0" Click="BtnAddPartner_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="➕" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="Новый партнер" FontSize="14"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnEditPartner" Style="{StaticResource BlueButton}"
            Margin="0,0,10,0" Click="BtnEditPartner_Click">
                            <TextBlock Text="Редактировать"/>
                        </Button>
                        <Button x:Name="BtnDeletePartner" Style="{StaticResource RedButton}"
            Margin="0,0,10,0" Click="BtnDeletePartner_Click">
                            <TextBlock Text="Удалить"/>
                        </Button>
                        <Button x:Name="BtnHistory" Style="{StaticResource OrangeButton}"
            Margin="0,0,10,0" Click="BtnHistory_Click">
                            <TextBlock Text="История"/>
                        </Button>
                        <Button x:Name="BtnRefresh" Style="{StaticResource PurpleButton}"
            Click="BtnRefresh_Click">
                            <TextBlock Text="Обновить"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Таблица партнеров -->
            <Border Grid.Row="1" Background="White" BorderBrush="#D5D8DC" BorderThickness="1">
                <Grid>
                    <!-- Заголовок таблицы -->
                    <Border Background="#34495E" Height="40" VerticalAlignment="Top">
                        <Grid Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ТИП" Foreground="#ECF0F1" 
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="НАИМЕНОВАНИЕ" Foreground="#ECF0F1" 
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="ДИРЕКТОР" Foreground="#ECF0F1" 
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="ТЕЛЕФОН" Foreground="#ECF0F1" 
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="EMAIL" Foreground="#ECF0F1" 
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="РЕЙТИНГ" Foreground="#ECF0F1" 
                                       FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="СКИДКА" Foreground="#ECF0F1" 
                                       FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Список партнеров с ListView для выбора -->
                    <ListView x:Name="PartnersListView"
                              Margin="0,40,0,0"
                              Background="Transparent"
                              BorderThickness="0"
                              SelectionMode="Single"
                              MouseDoubleClick="PartnersListView_MouseDoubleClick">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                        <Setter Property="BorderBrush" Value="#3498DB"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0F7FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" Padding="10,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding PartnerTypeName}" 
                                                   VerticalAlignment="Center" Foreground="#2C3E50"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" 
                                                   VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DirectorName}" 
                                                   VerticalAlignment="Center" Foreground="#7F8C8D"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Phone}" 
                                                   VerticalAlignment="Center" Foreground="#7F8C8D"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Email}" 
                                                   VerticalAlignment="Center" Foreground="#7F8C8D"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Rating}" 
                                                   VerticalAlignment="Center" HorizontalAlignment="Center" 
                                                   Foreground="#E67E22" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="6" Text="{Binding Discount, StringFormat={}{0}%}" 
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   Foreground="{Binding Discount, Converter={StaticResource DiscountToColorConverter}}" 
                                                   FontWeight="Bold"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- Нижняя панель (статус) -->
        <Border Grid.Row="2" Background="#ECF0F1" Padding="20" Margin="0,10,0,0"
                BorderBrush="#D5D8DC" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="TxtStatus" Text="Готов к работе" 
                           Foreground="#7F8C8D"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Последнее обновление: " Foreground="#95A5A6"/>
                    <TextBlock x:Name="TxtLastUpdate" Text="" 
                               Foreground="#3498DB" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>