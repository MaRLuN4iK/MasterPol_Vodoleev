<Window x:Class="MasterPol.App.PartnerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование партнера" 
        Height="700" Width="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="White" BorderBrush="#D5D8DC" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="#2C3E50">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="40" Height="40" Background="#3498DB">
                        <TextBlock x:Name="IconText" Text="✎" FontSize="20" FontWeight="Bold" 
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Grid.Column="1" x:Name="TblHeader" Text="Добавление нового партнера" 
                               FontSize="20" FontWeight="SemiBold" Foreground="White" 
                               VerticalAlignment="Center" Margin="15,0,0,0"/>

                    <Button Grid.Column="2" x:Name="BtnClose" Width="40" Height="40" 
                            Background="Transparent" BorderThickness="0" Click="BtnCancel_Click">
                        <TextBlock Text="✕" FontSize="20" Foreground="White"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Основное содержимое -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="30,20">
                <StackPanel>
                    <TextBlock Text="Тип партнера" FontSize="14" FontWeight="SemiBold" 
                               Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbPartnerType" Height="45" 
                              Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1"
                              Padding="10" Margin="0,0,0,20"
                              DisplayMemberPath="Name" SelectedValuePath="Id"/>

                    <TextBlock Text="Наименование компании" FontSize="14" FontWeight="SemiBold" 
                               Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtName" Height="45" 
                             Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1"
                             Padding="10" Margin="0,0,0,20"/>

                    <TextBlock Text="Юридический адрес" FontSize="14" FontWeight="SemiBold" 
                               Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtAddress" Height="45" 
                             Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1"
                             Padding="10" Margin="0,0,0,20"/>

                    <TextBlock Text="ИНН" FontSize="14" FontWeight="SemiBold" 
                               Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtINN" Height="45" 
                             Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1"
                             Padding="10" Margin="0,0,0,20"/>

                    <TextBlock Text="ФИО директора" FontSize="14" FontWeight="SemiBold" 
                               Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtDirector" Height="45" 
                             Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1"
                             Padding="10" Margin="0,0,0,20"/>

                    <TextBlock Text="Телефон" FontSize="14" FontWeight="SemiBold" 
                               Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtPhone" Height="45" 
                             Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1"
                             Padding="10" Margin="0,0,0,20"
                             ToolTip="Формат: +7(XXX)XXX-XX-XX"/>

                    <TextBlock Text="Email" FontSize="14" FontWeight="SemiBold" 
                               Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtEmail" Height="45" 
                             Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1"
                             Padding="10" Margin="0,0,0,20"/>

                    <TextBlock Text="Рейтинг" FontSize="14" FontWeight="SemiBold" 
                               Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtRating" Height="45" 
                             Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1"
                             Padding="10" Margin="0,0,0,10"/>

                    <TextBlock Text="* обязательные поля" FontSize="11" 
                               Foreground="#95A5A6" Margin="0,0,0,20"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Нижняя панель с кнопками -->
            <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Все поля будут сохранены" 
                               Foreground="#95A5A6" VerticalAlignment="Center"/>

                    <Button Grid.Column="1" x:Name="BtnCancel" Content="Отмена" 
                            Width="120" Height="45" Background="#E74C3C" 
                            Foreground="White" BorderThickness="0"
                            Margin="0,0,10,0" Click="BtnCancel_Click"/>

                    <Button Grid.Column="2" x:Name="BtnSave" Content="Сохранить" 
                            Width="120" Height="45" Background="#27AE60" 
                            Foreground="White" BorderThickness="0"
                            Click="BtnSave_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>