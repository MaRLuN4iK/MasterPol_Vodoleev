<Window x:Class="MasterPol.App.SaleHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="История продаж" 
        Height="800" Width="1000"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        FontFamily="Segoe UI"
        Background="#F5F7FA">

    <Window.Resources>
        <Style x:Key="ChartCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и кнопка добавления -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Border Width="40" Height="40" Background="#E67E22" CornerRadius="8">
                    <TextBlock Text="📊" FontSize="20" Foreground="White" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="TblHeader" 
                           Text="История продаж" 
                           FontSize="24" FontWeight="SemiBold" 
                           Foreground="#2C3E50" 
                           VerticalAlignment="Center" Margin="15,0,0,0"/>
            </StackPanel>

            <Button Grid.Column="1" x:Name="BtnAddSale" 
                    Content="➕ Добавить продажу" 
                    Width="160" Height="40"
                    Background="#27AE60" 
                    Foreground="White" 
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="BtnAddSale_Click"/>
        </Grid>

        <!-- Карточка с графиком -->
        <Border Grid.Row="1" Style="{StaticResource ChartCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="250"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Динамика продаж по месяцам" 
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="#2C3E50" Margin="0,0,0,15"/>

                <!-- График -->
                <lvc:CartesianChart Grid.Row="1" x:Name="SalesChart" 
                                    LegendLocation="Top" 
                                    Hoverable="True"
                                    DataTooltip="{x:Null}"
                                    Margin="0,0,0,10">
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Title="Месяцы" 
                                  Labels="{Binding MonthLabels}"
                                  FontSize="12"
                                  Foreground="#7F8C8D"/>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Сумма продаж (₽)" 
                                  LabelFormatter="{Binding YFormatter}"
                                  FontSize="12"
                                  Foreground="#7F8C8D"/>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Grid>
        </Border>

        <!-- Таблица истории продаж -->
        <Border Grid.Row="2" Background="White" 
                BorderBrush="#E0E0E0" BorderThickness="1" 
                Padding="0" Margin="0,0,0,20">
            <Grid>
                <!-- Заголовок таблицы -->
                <Border Background="#34495E" Height="40" VerticalAlignment="Top">
                    <Grid Margin="15,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ДАТА" Foreground="#ECF0F1" 
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="ПРОДУКЦИЯ" Foreground="#ECF0F1" 
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="АРТИКУЛ" Foreground="#ECF0F1" 
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="КОЛ-ВО" Foreground="#ECF0F1" 
                                   FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="ЦЕНА" Foreground="#ECF0F1" 
                                   FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="5" Text="СУММА" Foreground="#ECF0F1" 
                                   FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- Список продаж -->
                <ListView x:Name="HistoryListView"
                          Margin="0,40,0,0"
                          Background="Transparent"
                          BorderThickness="0"
                          ItemsSource="{Binding}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Padding="15,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="250"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding SaleDate, StringFormat={}{0:dd.MM.yyyy}}" 
                                               Foreground="#2C3E50" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ProductName}" 
                                               Foreground="#2C3E50" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ProductArticle}" 
                                               Foreground="#7F8C8D" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Quantity}" 
                                               Foreground="#7F8C8D" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="{Binding Price, StringFormat={}{0:N2} ₽}" 
                                               Foreground="#7F8C8D" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="5" Text="{Binding Total, StringFormat={}{0:N2} ₽}" 
                                               Foreground="#27AE60" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Нижняя панель с итогами -->
        <Border Grid.Row="3" Background="#F8F9FA" 
                BorderBrush="#E0E0E0" BorderThickness="1" 
                Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="TxtTotal" 
                               FontSize="24" FontWeight="Bold" 
                               Foreground="#27AE60" Text="0 ₽"/>
                    <TextBlock Text="Общая сумма всех продаж" FontSize="14" 
                               Foreground="#7F8C8D" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,20,0">
                    <Border Background="#3498DB" Width="20" Height="12" Margin="0,0,5,0"/>
                    <TextBlock Text="Сумма продаж" Foreground="#2C3E50" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="2" x:Name="BtnCloseWindow" 
                        Content="Закрыть" 
                        Width="120" Height="40" 
                        Background="#3498DB" 
                        Foreground="White" 
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Click="BtnClose_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>