<Window x:Class="MasterPol.App.AddSaleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление продажи" 
        Height="720" Width="550"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Background="#F5F7FA">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок с иконкой -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
            <Border Width="40" Height="40" Background="#27AE60" CornerRadius="8">
                <TextBlock Text="💰" FontSize="20" Foreground="White" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="TblHeader" 
                       Text="Добавление новой продажи" 
                       FontSize="20" FontWeight="SemiBold" 
                       Foreground="#2C3E50" 
                       VerticalAlignment="Center" Margin="15,0,0,0"/>
        </StackPanel>

        <!-- Поля ввода -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Информация о партнере (выделенный блок) -->
                <Border Background="#E8F5E9" Padding="15" Margin="0,0,0,25" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="ПАРТНЕР" FontSize="12" FontWeight="Bold" 
                                   Foreground="#2E7D32" Margin="0,0,0,5"/>
                        <TextBlock x:Name="TxtPartnerInfo" 
                                   Text="Партнер: " 
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="#1B5E20"/>
                    </StackPanel>
                </Border>

                <!-- Продукция -->
                <TextBlock Text="Продукция *" FontSize="14" FontWeight="SemiBold" 
                           Foreground="#2C3E50" Margin="0,0,0,5"/>
                <ComboBox x:Name="CmbProduct" 
                          Height="45" 
                          Background="White" 
                          BorderBrush="#E0E0E0" 
                          BorderThickness="1"
                          Padding="10" 
                          Margin="0,0,0,20"
                          DisplayMemberPath="DisplayName" 
                          SelectedValuePath="Id"/>

                <!-- Артикул (новое поле) -->
                <TextBlock Text="Артикул" FontSize="14" FontWeight="SemiBold" 
                           Foreground="#2C3E50" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtArticle" 
                         Height="45" 
                         Background="#F5F5F5" 
                         BorderBrush="#E0E0E0" 
                         BorderThickness="1"
                         Padding="10" 
                         Margin="0,0,0,20"
                         IsReadOnly="True"
                         Text="Выберите продукцию для отображения артикула"/>

                <!-- Количество -->
                <TextBlock Text="Количество *" FontSize="14" FontWeight="SemiBold" 
                           Foreground="#2C3E50" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtQuantity" 
                         Height="45" 
                         Background="White" 
                         BorderBrush="#E0E0E0" 
                         BorderThickness="1"
                         Padding="10" 
                         Margin="0,0,0,20"
                         PreviewTextInput="TxtQuantity_PreviewTextInput"/>

                <!-- Цена за единицу (информационно) -->
                <TextBlock Text="Цена за единицу" FontSize="14" FontWeight="SemiBold" 
                           Foreground="#2C3E50" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtPrice" 
                         Height="45" 
                         Background="#F5F5F5" 
                         BorderBrush="#E0E0E0" 
                         BorderThickness="1"
                         Padding="10" 
                         Margin="0,0,0,20"
                         IsReadOnly="True"
                         Text="0.00 ₽"/>

                <!-- Дата продажи -->
                <TextBlock Text="Дата продажи *" FontSize="14" FontWeight="SemiBold" 
                           Foreground="#2C3E50" Margin="0,0,0,5"/>
                <DatePicker x:Name="DatePickerSale" 
                            Height="45" 
                            Background="White" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="1"
                            Padding="5" 
                            Margin="0,0,0,15"
                            SelectedDate="{Binding Date, Mode=TwoWay}"/>

                <!-- Общая сумма (предварительный расчет) -->
                <Border Background="#F0F7FF" Padding="15" Margin="0,15,0,0" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="ПРЕДВАРИТЕЛЬНАЯ СУММА" FontSize="12" FontWeight="Bold" 
                                   Foreground="#1976D2" Margin="0,0,0,5"/>
                        <TextBlock x:Name="TxtTotalPreview" 
                                   Text="0.00 ₽" 
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="#0D47A1"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="* - обязательные поля" 
                           FontSize="11" 
                           Foreground="#95A5A6" 
                           Margin="0,15,0,10"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnSave" 
                    Content="Сохранить продажу" 
                    Width="150" Height="40" 
                    Margin="0,0,10,0"
                    Click="BtnSave_Click"
                    Background="#27AE60"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"/>
            <Button x:Name="BtnCancel" 
                    Content="Отмена" 
                    Width="100" Height="40"
                    Click="BtnCancel_Click"
                    Background="#E74C3C"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>